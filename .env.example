# Database
DATABASE_URL=postgresql://halacha:halacha@localhost:5433/halacha_ai
REDIS_URL=redis://localhost:6380

# Embedding API (BGE-M3 via HuggingFace Inference API or compatible endpoint)
EMBEDDING_API_URL=https://router.huggingface.co/models/BAAI/bge-m3
EMBEDDING_API_KEY=hf_your_key_here
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# LLM Provider (anthropic, openai, or perplexity)
# Perplexity recommended for: cost efficiency, web grounding, automatic citations
LLM_PROVIDER=perplexity

# Perplexity API (recommended - https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_key_here
# Models: sonar (fast), sonar-pro (best), sonar-reasoning (analytical)
# Can also use: llama-3.1-sonar-large-128k-online, llama-3.1-sonar-huge-128k-online
LLM_MODEL=sonar-pro

# Anthropic API (alternative)
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Model: claude-sonnet-4-20250514, claude-opus-4-20250514

# OpenAI API (alternative)
OPENAI_API_KEY=sk-your_key_here
# Model: gpt-4o, gpt-4-turbo, gpt-4

# Sefaria Export data path
SEFARIA_EXPORT_PATH=X:/Halacha/Sefaria-Export

# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Get a Perplexity API key: https://www.perplexity.ai/settings/api
# 3. Set PERPLEXITY_API_KEY in .env
# 4. (Optional) Configure other providers for fallback/comparison
