# Database
DATABASE_URL=postgresql://halacha:halacha@localhost:5433/halacha_ai
REDIS_URL=redis://localhost:6380

# Embedding API (BGE-M3 via HuggingFace Inference API or compatible endpoint)
EMBEDDING_API_URL=https://router.huggingface.co/models/BAAI/bge-m3
EMBEDDING_API_KEY=hf_your_key_here
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ============================================================================
# INTELLIGENT MULTI-AI SYSTEM
# ============================================================================
# The system automatically selects the best AI model for each task:
#
# PRACTICAL MODE (day-to-day halakhic questions):
#   → Perplexity Sonar Pro (web-grounded, recent responsa, citations)
#   → Fallback: GPT-4o → Claude Sonnet
#
# DEEP ANALYSIS MODE (complex philosophical questions):
#   → Claude Sonnet 4 (deep reasoning, nuanced analysis)
#   → Fallback: Perplexity Reasoning → GPT-4o
#
# POSEK VIEW MODE (authoritative rulings):
#   → Claude Sonnet 4 (authoritative perspective)
#   → Fallback: Perplexity Sonar Pro → GPT-4o
#
# Configure one or more providers below. The system will:
# 1. Choose the optimal model for each query type
# 2. Automatically fallback if primary provider fails
# 3. Handle credit/quota issues gracefully
# ============================================================================

# LLM Provider Mode
# - "auto" (default): Intelligent task-based routing
# - "perplexity": Force all queries to Perplexity
# - "anthropic": Force all queries to Claude
# - "openai": Force all queries to GPT
LLM_PROVIDER=auto

# Model Override (only used when LLM_PROVIDER is not "auto")
LLM_MODEL=auto

# ============================================================================
# RECOMMENDED SETUP: Configure all three for best results
# ============================================================================

# Perplexity API (https://www.perplexity.ai/settings/api)
# Best for: Practical queries, web research, recent responsa
# Cost: $1-15 per 1M tokens (most cost-effective for practical mode)
PERPLEXITY_API_KEY=pplx-your_key_here

# Anthropic Claude API (https://console.anthropic.com/)
# Best for: Deep analysis, complex reasoning, authoritative rulings
# Cost: $3-15 per 1M tokens (premium for analytical depth)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI API (https://platform.openai.com/api-keys)
# Best for: Balanced general responses, reliable fallback
# Cost: $2.50-15 per 1M tokens (good middle ground)
OPENAI_API_KEY=sk-your_key_here

# ============================================================================
# COST OPTIMIZATION TIPS
# ============================================================================
# Budget-friendly: Configure PERPLEXITY_API_KEY only ($1-3/1M tokens)
# Balanced: Configure PERPLEXITY + OPENAI (~$1.50-9/1M tokens avg)
# Premium: Configure all three for optimal quality per task
# Enterprise: All three with generous quotas for zero-downtime fallback
# ============================================================================

# Sefaria Export data path
SEFARIA_EXPORT_PATH=X:/Halacha/Sefaria-Export

# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Get API keys from providers above
# 3. Configure at least PERPLEXITY_API_KEY for immediate use
# 4. (Recommended) Configure all three for intelligent routing
# 5. Leave LLM_PROVIDER=auto for optimal model selection
