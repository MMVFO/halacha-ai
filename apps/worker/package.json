{
  "name": "@halacha-ai/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "tsx index.ts",
    "enqueue": "tsx enqueue.ts",
    "ingest": "tsx ingest-sefaria.ts",
    "ingest:dry": "tsx ingest-sefaria.ts --dry-run",
    "ingest:kabbalah": "tsx ingest-sefaria.ts --category Kabbalah",
    "ingest:halakhah": "tsx ingest-sefaria.ts --category Halakhah",
    "ingest:talmud": "tsx ingest-sefaria.ts --category Talmud",
    "ingest:chasidut": "tsx ingest-sefaria.ts --category Chasidut",
    "ingest:otzaria": "tsx ingest-otzaria.ts",
    "ingest:otzaria:dry": "tsx ingest-otzaria.ts --dry-run",
    "ingest:otzaria:kabbalah": "tsx ingest-otzaria.ts --category קבלה",
    "embed": "tsx embed-bulk.ts",
    "embed:dry": "tsx embed-bulk.ts --dry-run",
    "embed:test": "tsx embed-bulk.ts --limit 100",
    "inventory": "tsx corpus-inventory.ts",
    "inventory:json": "tsx corpus-inventory.ts --json --no-save",
    "scrape:hebrewbooks": "tsx scrape-hebrewbooks.ts",
    "scrape:hebrewbooks:dry": "tsx scrape-hebrewbooks.ts --dry-run --limit 20",
    "scrape:hebrewbooks:subjects": "tsx scrape-hebrewbooks.ts --list-subjects"
  },
  "dependencies": {
    "bullmq": "^5.25.0",
    "ioredis": "^5.4.0",
    "@halacha-ai/db": "workspace:*",
    "@halacha-ai/lib": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
