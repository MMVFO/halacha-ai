{
  "name": "halacha-ai",
  "version": "0.1.0",
  "private": true,
  "description": "RAG-based halakhic research system",
  "scripts": {
    "dev": "pnpm --filter @halacha-ai/web dev",
    "build": "pnpm --filter @halacha-ai/web build",
    "worker": "pnpm --filter @halacha-ai/worker start",
    "db:migrate": "pnpm --filter @halacha-ai/db migrate",
    "ingest": "pnpm --filter @halacha-ai/worker ingest",
    "ingest:dry": "pnpm --filter @halacha-ai/worker ingest:dry",
    "ingest:kabbalah": "pnpm --filter @halacha-ai/worker ingest:kabbalah",
    "ingest:halakhah": "pnpm --filter @halacha-ai/worker ingest:halakhah",
    "ingest:talmud": "pnpm --filter @halacha-ai/worker ingest:talmud",
    "ingest:chasidut": "pnpm --filter @halacha-ai/worker ingest:chasidut",
    "enqueue": "pnpm --filter @halacha-ai/worker enqueue",
    "check-updates": "tsx scripts/check-updates.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract", "sharp"]
  }
}
